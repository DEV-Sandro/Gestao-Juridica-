rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ============================================================
    // AVATARS — cada usuário só pode escrever no seu próprio diretório
    // ============================================================
    // Path: /avatars/{uid}/{nome-do-arquivo}
    match /avatars/{uid}/{arquivo=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024 // 5MB max
        && request.resource.contentType.matches('image/(jpeg|jpg|png|webp)');
    }

    // ============================================================
    // TEMPLATES (Feature 2 — futuro) — só admin escreve
    // ============================================================
    match /templates/{templateId}/{arquivo=**} {
      allow read: if request.auth != null;
      allow write: if false; // Apenas via Admin SDK no backend
    }

    // ============================================================
    // FALLBACK — bloqueia tudo o resto
    // ============================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
